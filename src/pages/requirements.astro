---
import BaseLayout from "@layouts/BaseLayout.astro";
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";
---

<BaseLayout title="CDL-A Driver Requirements | MNS1 Express" description="No hidden disqualifiers. No wasted time. Here are the exact requirements to drive for MNS1 Express.">
  <PageHero
    eyebrow="Requirements"
    title="Do You Qualify? Here's Everything."
    lead="No hidden disqualifiers. No wasted time. Here are the exact requirements to drive for MNS1 Express. If you meet them, apply in 4 mins."
  />
  <section class="section">
    <div class="wrap split">
      <div>
        <p class="eyebrow">Core Requirements</p>
        <h2>The Basics</h2>
        <div class="requirement-cards">
          <article class="card requirement-card"><span>01</span><h3>Age</h3><p>25 years or older</p></article>
          <article class="card requirement-card"><span>02</span><h3>CDL Experience</h3><p>24 months Class A CDL required</p></article>
          <article class="card requirement-card"><span>03</span><h3>Medical</h3><p>Current DOT physical card</p></article>
          <article class="card requirement-card"><span>04</span><h3>Job History</h3><p>Max 4 jobs in the last 12 months</p></article>
          <article class="card requirement-card"><span>05</span><h3>Criminal/DUI</h3><p>No DUI or felonies in the last 5 years</p></article>
          <article class="card requirement-card"><span>06</span><h3>SAP Program</h3><p>No SAP (Substance Abuse Professional) history</p></article>
        </div>
      </div>
      <aside class="panel">
        <h3>Driving Record (MVR)</h3>
        <p>Motor Vehicle Record Standards</p>
        <p>Your MVR tells us about your driving history. Here's exactly what we're looking at:</p>
        <ul class="check-list">
          <li>5-Year Major Violations: No major violations in the last 5 years. This includes reckless driving, hit-and-run, and driving under suspension.</li>
          <li>1-Year Moving Violations: Maximum 2 moving violations (tickets) in the last 12 months.</li>
          <li>3-Year Accident History: Maximum 1 at-fault accident in the last 3 years.</li>
        </ul>
      </aside>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap split">
      <div>
        <p class="eyebrow">Bring to Orientation</p>
        <h2>Required Documents</h2>
        <p>Have these ready for your 2-day orientation in Plainfield, IL:</p>
        <ul class="check-list">
          <li>Valid Class A CDL</li>
          <li>Current DOT Medical Card</li>
          <li>Social Security Card</li>
          <li>Voided Check (for direct deposit)</li>
        </ul>
      </div>
      <aside class="panel">
        <p class="eyebrow">Quick Self-Check</p>
        <h3>Not Sure If You Qualify?</h3>
        <p>If you can answer "yes" to all of these, you're good to apply:</p>
        <ul class="check-list">
          <li>I'm 25 years old or older</li>
          <li>I have 24+ months of Class A CDL experience</li>
          <li>I have a current DOT physical</li>
          <li>I've had 4 or fewer jobs in the last 12 months</li>
          <li>No DUI or felony convictions in 5 years</li>
          <li>No SAP history</li>
          <li>Clean-ish MVR (see details above)</li>
          <li>I live in one of MNS1's Midwest hiring areas</li>
        </ul>
      </aside>
    </div>
  </section>
  <section class="section">
    <div class="wrap panel">
      <h2>Meet the Requirements?</h2>
      <p>The application takes about 4 minutes. A recruiter will review your info and reach out within 24 hours.</p>
      <div class="hero-actions">
        <CtaButton />
        <a class="button-secondary" href="tel:6302463280">630-246-3280</a>
      </div>
    </div>
  </section>
</BaseLayout>
