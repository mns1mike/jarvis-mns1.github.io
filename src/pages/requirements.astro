---
import BaseLayout from "@layouts/BaseLayout.astro";
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";
import { site } from "@data/site";

const checkIcon =
  "display:block;width:20px;height:20px;margin-bottom:14px;color:var(--color-blue);fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round";
const rowIcon =
  "display:block;width:18px;height:18px;color:var(--color-blue);fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0";

const requirements = [
  ["Age", "25 years or older"],
  ["CDL Experience", "24 months Class A CDL required"],
  ["Medical", "Current DOT physical card"],
  ["Job History", "Max 4 jobs in the last 12 months"],
  ["Criminal/DUI", "No DUI or felonies in the last 5 years"],
  ["SAP Program", "No SAP (Substance Abuse Professional) history"],
];

const documents = [
  "Valid Class A CDL",
  "Current DOT Medical Card",
  "Social Security Card",
  "Voided Check (for direct deposit)",
];

const selfCheckItems = [
  "I'm 25 years old or older",
  "I have 24+ months of Class A CDL experience",
  "I have a current DOT physical",
  "I've had 4 or fewer jobs in the last 12 months",
  "No DUI or felony convictions in 5 years",
  "No SAP history",
  "Clean-ish MVR (see details above)",
  "I live in one of MNS1's Midwest hiring areas",
];
---

<BaseLayout title="CDL-A Driver Requirements | MNS1 Express" description="No hidden disqualifiers. No wasted time. Here are the exact requirements to drive for MNS1 Express.">
  <PageHero
    eyebrow="Requirements"
    title="Do You Qualify? Here's Everything."
    lead="No hidden disqualifiers. No wasted time. Here are the exact requirements to drive for MNS1 Express. If you meet them, apply in 4 mins."
  >
    <div class="hero-actions">
      <CtaButton />
    </div>
  </PageHero>
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Core Requirements</p>
      <h2>The Basics</h2>
      <div class="requirement-cards">
        {requirements.map(([title, description]) => (
          <article class="card requirement-card">
            <svg aria-hidden="true" viewBox="0 0 24 24" style={checkIcon}>
              <path d="M21.8 10A10 10 0 1 1 17 3.3" />
              <path d="m9 11 3 3L22 4" />
            </svg>
            <h3>{title}</h3>
            <p>{description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap panel">
      <p class="eyebrow">Driving Record (MVR)</p>
      <h2>Motor Vehicle Record Standards</h2>
      <p>Your MVR tells us about your driving history. Here's exactly what we're looking at:</p>
      <ul class="check-list">
        <li>5-Year Major Violations: No major violations in the last 5 years. This includes reckless driving, hit-and-run, and driving under suspension.</li>
        <li>1-Year Moving Violations: Maximum 2 moving violations (tickets) in the last 12 months.</li>
        <li>3-Year Accident History: Maximum 1 at-fault accident in the last 3 years.</li>
      </ul>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Bring to Orientation</p>
        <h2>Required Documents</h2>
        <p>Have these ready for your 2-day orientation in Plainfield, IL:</p>
      </div>
      <div class="requirement-cards">
        {documents.map((document) => (
          <article class="card requirement-card">
            <svg aria-hidden="true" viewBox="0 0 24 24" style={checkIcon}>
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
              <path d="M14 2v4a2 2 0 0 0 2 2h4" />
              <path d="M10 9H8" />
              <path d="M16 13H8" />
              <path d="M16 17H8" />
            </svg>
            <h3>{document}</h3>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="wrap section-heading" style="max-width:640px">
      <p class="eyebrow">Quick Self-Check</p>
      <h2>Not Sure If You Qualify?</h2>
      <p>If you can answer "yes" to all of these, you're good to apply:</p>
      <div style="display:flex;flex-direction:column;gap:14px;margin-top:24px">
        {selfCheckItems.map((item) => (
          <div style="display:flex;align-items:center;gap:12px;color:var(--color-muted);font:600 15px/1.5 var(--font-body)">
            <svg aria-hidden="true" viewBox="0 0 24 24" style={rowIcon}>
              <path d="M21.8 10A10 10 0 1 1 17 3.3" />
              <path d="m9 11 3 3L22 4" />
            </svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap panel" style="max-width:640px;text-align:center">
      <h2>Meet the Requirements?</h2>
      <p>The application takes about 4 minutes. A recruiter will review your info and reach out within 24 hours.</p>
      <div class="hero-actions" style="justify-content:center">
        <CtaButton />
        <a class="button-secondary" href={site.phoneHref}>{site.phoneDisplay}</a>
      </div>
    </div>
  </section>
</BaseLayout>
