---
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";
import { site } from "@data/site";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Apply for CDL-A Regional Driver Jobs | MNS1 Express"
  description="Use the official IntelliApp application for MNS1 Express driver openings. Top drivers average $1,650-$1,900+ gross per week with Midwest regional lanes, 2023+ Freightliners, and weekend home time."
>
  <meta slot="head" http-equiv="refresh" content={`10; url=${site.applyUrl}`} />
  <PageHero
    eyebrow="CDL-A Driver Application"
    title="Apply With MNS1 Express"
    lead="Use the official IntelliApp application for MNS1 Express driver openings. Top drivers average $1,650-$1,900+ gross per week with Midwest regional lanes, 2023+ Freightliners, and weekend home time."
  >
    <div class="hero-actions">
      <CtaButton />
      <a class="button-secondary" href={site.phoneHref}>{site.phoneDisplay}</a>
    </div>
  </PageHero>

  <section class="section">
    <div class="wrap panel">
      <h2>Prefer to talk first?</h2>
      <p>Reach recruiting at <a class="text-link" href={site.phoneHref}>{site.phoneDisplay}</a> or email <a class="text-link" href={`mailto:${site.recruitingEmail}`}>{site.recruitingEmail}</a>.</p>
      <p>You will be redirected to IntelliApp automatically in a few seconds.</p>
    </div>
  </section>
</BaseLayout>
