---
import BaseLayout from "@layouts/BaseLayout.astro";
import CtaButton from "@components/CtaButton.astro";
---

<BaseLayout
  title="MNS1 Express, Top Pay. Real Respect. CDL-A Driver Jobs Midwest"
  description="CDL-A regional driver jobs with MNS1 Express. Top drivers average $1,650-$1,900+ weekly. 2023+ Freightliners. Home every weekend. Midwest dry van freight."
  preloadHero
>
  <section class="hero hero--image">
    <div class="wrap hero-grid">
      <div>
        <p class="eyebrow">Always forward. · Hiring CDL-A across 11 states</p>
        <h1 class="display-title">Top pay.<br /><span>Real respect.</span><br /><em>A truck you'll be proud to drive.</em></h1>
        <p class="lead">
          Earn up to $1,650-$1,900/wk running the Midwest in a 2023 or newer Freightliner Cascadia.
          Weekly direct deposit, consistent miles, planned loads, and a dispatcher who calls you by name.
          Family-owned in Plainfield, IL since 2011.
        </p>
        <div class="hero-actions">
          <CtaButton />
          <a class="button-secondary" href="tel:6302463280">Call 630-246-3280</a>
        </div>
        <div class="trust-row" aria-label="Driver highlights">
          <span>Top drivers $1,650-$1,900/wk</span>
          <span>2023+ Freightliners</span>
          <span>Home weekly · consistent miles</span>
        </div>
      </div>
      <div class="quick-panel">
        <p class="eyebrow">4-Minute Quick Apply</p>
        <h2>See what you'd earn</h2>
        <p>A recruiter calls back within 15 minutes. Real person, no bots, no robocalls.</p>
        <form class="quick-form" action="https://intelliapp.driverapponline.com/c/mns1express?r=CompanyWebsite" method="get">
          <label>
            <span>First name</span>
            <input type="text" name="first_name" autocomplete="given-name" placeholder="First name" />
          </label>
          <label>
            <span>Mobile phone</span>
            <input type="tel" name="phone" autocomplete="tel" placeholder="Mobile phone" />
          </label>
          <label>
            <span>Email optional</span>
            <input type="email" name="email" autocomplete="email" placeholder="Email (optional)" />
          </label>
          <div class="quick-form__row">
            <label>
              <span>ZIP</span>
              <input type="text" name="zip" autocomplete="postal-code" placeholder="ZIP" />
            </label>
            <label>
              <span>Experience</span>
              <select name="experience">
                <option value="" selected>CDL-A experience</option>
                <option>2+ years CDL-A</option>
                <option>1-2 years CDL-A</option>
                <option>New CDL-A</option>
              </select>
            </label>
          </div>
          <button type="submit">Get my match -></button>
        </form>
        <div class="quick-panel__proof">
          <span>CDL-A experience</span>
          <span>SSL encrypted</span>
          <span>We never sell your info</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--panel home-stat-strip">
    <div class="wrap stat-grid">
      <article><strong>180+</strong><span>Trucks on the road</span></article>
      <article><strong>2011</strong><span>Family-owned since</span></article>
      <article><strong>16</strong><span>States we run</span></article>
      <article><strong>11</strong><span>States we hire</span></article>
    </div>
  </section>

  <section class="section">
    <div class="wrap section-heading">
      <p class="eyebrow">The MNS1 way</p>
      <h2>Four things we promise. And mean every word.</h2>
      <a class="text-link" href="/pay/">See the full pay sheet</a>
    </div>
    <div class="wrap grid grid--cards">
      <article class="card">
        <p class="eyebrow">01</p>
        <h2>Freedom on the road</h2>
        <p>Consistent miles, planned loads. Your dispatcher knows your name and works with your schedule, not against it.</p>
        <p class="card-stat"><strong>24/7</strong> dispatch that picks up</p>
      </article>
      <article class="card">
        <p class="eyebrow">02</p>
        <h2>Earn what you're worth</h2>
        <p>Top drivers $1,650-$1,900/wk, paid weekly. Detention, stop, layover, every accessorial is published, not promised.</p>
        <p class="card-stat"><strong>$0.68</strong> top driver mile rate</p>
      </article>
      <article class="card">
        <p class="eyebrow">03</p>
        <h2>Trucks built for the long haul</h2>
        <p>2023 or newer Freightliner Cascadias. eAPU, double bunk, inverter, fridge, standard on every truck.</p>
        <p class="card-stat"><strong>2023+</strong> Freightliner Cascadia</p>
      </article>
      <article class="card">
        <p class="eyebrow">04</p>
        <h2>Home time, your way</h2>
        <p>Weekly, bi-weekly, or hometown lanes, talk to dispatch and we'll build the rotation around your life.</p>
        <p class="card-stat"><strong>Weekly</strong> home for most drivers</p>
      </article>
    </div>
  </section>

  <section class="section section--panel reviews-section">
    <div class="wrap section-heading">
      <p class="eyebrow">Driver reviews</p>
      <h2>What drivers say. Linked to the source.</h2>
      <p class="lead-small">A few of the stronger public reviews from Google, Indeed, and Facebook. Each card links out so drivers can read more before applying.</p>
    </div>
    <div class="review-rail">
      <div class="review-track">
        <article class="card review-card"><p class="eyebrow">Google · 5-star review</p><h2>Home time + dispatch</h2><p>"MNS1 does what they say. They get you home every weekend, pay is always correct every Friday, and dispatch communicates with their drivers."</p></article>
        <article class="card review-card"><p class="eyebrow">Indeed · Driver review</p><h2>Pay + miles</h2><p>"I get great pay and good miles, I am home every Friday and go back out every Monday. The people here are professional and care about you as a driver."</p></article>
        <article class="card review-card"><p class="eyebrow">Facebook · Driver recommendation</p><h2>Equipment + support</h2><p>"Great pay, latest equipment, weekly home time, and support. The company really held me here."</p></article>
        <article class="card review-card" aria-hidden="true"><p class="eyebrow">Google · 5-star review</p><h2>Home time + dispatch</h2><p>"MNS1 does what they say. They get you home every weekend, pay is always correct every Friday, and dispatch communicates with their drivers."</p></article>
        <article class="card review-card" aria-hidden="true"><p class="eyebrow">Indeed · Driver review</p><h2>Pay + miles</h2><p>"I get great pay and good miles, I am home every Friday and go back out every Monday. The people here are professional and care about you as a driver."</p></article>
        <article class="card review-card" aria-hidden="true"><p class="eyebrow">Facebook · Driver recommendation</p><h2>Equipment + support</h2><p>"Great pay, latest equipment, weekly home time, and support. The company really held me here."</p></article>
      </div>
    </div>
  </section>

  <section class="section home-equipment-section" id="equipment">
    <div class="wrap">
      <div class="home-equipment-heading">
        <div>
          <p class="eyebrow">The equipment</p>
          <h2>One brand. One spec.<br /><span>2023 or newer Cascadias.</span></h2>
        </div>
        <p>We picked the Cascadia and stuck with it. Every truck spec'd the same way means our shop knows them inside out, and roadside fixes happen fast. In-house shop at our Plainfield, IL terminal.</p>
      </div>
      <div class="equipment-card-grid">
        <article class="equipment-photo-card">
          <img src="/images/site/mns1-truck-placeholder.jpg" alt="MNS1 Freightliner Cascadia tractor parked in fleet colors" loading="lazy" decoding="async" />
          <div class="equipment-photo-card__body">
            <p class="eyebrow">2025 · Double Bunk</p>
            <h3>Freightliner Cascadia</h3>
            <p>72'' Double Bunk · Detroit DD15 · 505 hp<br />DT12 Automated · eAPU · Inverter · Microwave</p>
          </div>
          <div class="equipment-photo-card__meta">
            <span>Standard</span>
            <strong>eAPU · Inverter · Microwave</strong>
          </div>
        </article>
        <article class="equipment-photo-card">
          <img src="/images/site/mns1-trailer-placeholder.jpg" alt="MNS1 dry van trailer in the yard" loading="lazy" decoding="async" />
          <div class="equipment-photo-card__body">
            <p class="eyebrow">53' Dry Van</p>
            <h3>Trailer</h3>
            <p>Standard 53' dry van trailers<br />Well-maintained · Road-ready</p>
          </div>
          <div class="equipment-photo-card__meta">
            <span>Fleet</span>
            <strong>Dry Van · 53'</strong>
          </div>
        </article>
      </div>
      <p class="home-equipment-link"><a class="text-link" href="/equipment/">See full equipment details</a></p>
    </div>
  </section>

  <section class="section section--panel home-map-section">
    <div class="wrap home-map-grid">
      <div class="home-map-copy">
        <p class="eyebrow">Where we run</p>
        <h2>16 states. One Midwest backbone.</h2>
        <p>Our lanes run through 16 states from our Plainfield, IL headquarters. We run the corridors we know, the shippers we trust, and the lanes that get drivers home.</p>
        <div class="home-hq-card">
          <span aria-hidden="true">⌖</span>
          <p><strong>Plainfield, IL, HQ</strong><br />14458 S Depot Dr · Shop · Orientation · Dispatch</p>
        </div>
      </div>
      <aside class="home-map-panel" aria-label="Midwest lane coverage">
        <div class="home-map-frame" role="img" aria-label="MNS1 Midwest lane coverage map"></div>
        <div class="home-map-legend">
          <span><strong>16</strong> states active</span>
          <span><strong>11</strong> hiring states</span>
          <a class="text-link" href="/lanes/">View lanes & coverage</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section home-shipper-section" id="shippers">
    <div class="wrap home-shipper-grid">
      <div class="home-shipper-copy">
        <p class="eyebrow">For shippers</p>
        <h2>Freight that moves{" "}<br /><span>when you said it would.</span></h2>
        <p>We're a Midwest carrier with our own equipment, our own drivers, and our own dispatch desk, not a broker passing your load down a chain. One number, one team, one account owner accountable for your freight.</p>
        <div class="home-shipper-stats">
          <div><strong>99.4%</strong><span>On-time delivery (rolling 12-mo)</span></div>
          <div><strong>&lt;3 hr</strong><span>Avg quote turnaround</span></div>
          <div><strong>180+</strong><span>Trucks ready to dispatch</span></div>
          <div><strong>1</strong><span>Account manager. Yours.</span></div>
        </div>
        <div class="hero-actions">
          <a class="button-secondary" href="/contact/">Get a quote</a>
          <a class="button-secondary" href="tel:6302463280">630-246-3280</a>
        </div>
      </div>
      <aside class="home-shipper-services" aria-label="Shipper service highlights">
        <article>
          <span>01</span>
          <h3>Dry van</h3>
          <p>53' dry vans, it's all we run, and nobody does it better.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Drop trailers</h3>
          <p>Pre-loaded trailers ready at your dock. Less wait time, more freight moving.</p>
        </article>
        <article>
          <span>03</span>
          <h3>24/7/365 support</h3>
          <p>Real people answering real calls: nights, weekends, holidays.</p>
        </article>
        <article>
          <span>04</span>
          <h3>Full GPS tracking</h3>
          <p>Live visibility on every load. Trucks and trailers are GPS-equipped.</p>
        </article>
      </aside>
    </div>
  </section>

  <section class="section home-story-section">
    <div class="wrap home-story-grid">
      <div class="home-story-copy">
        <p class="eyebrow">Our story</p>
        <h2>Started with one truck.{" "}<br /><span>Built on one promise.</span></h2>
        <p>In 2011, we put one truck on the road from Plainfield, Illinois with a simple idea, treat drivers and shippers the way you'd want to be treated. No shortcuts on equipment, no bait-and-switch on pay, no broker games on freight.</p>
        <p>Fourteen years and 180+ trucks later, that's still the company. Family-owned. Always forward.</p>
        <div class="home-founder-note">
          <span aria-hidden="true">MN</span>
          <p>"You run good equipment, pay drivers fair, and answer the phone. Everything else is a shortcut."<br /><strong>Founder · MNS1 Express</strong></p>
        </div>
      </div>
      <aside class="home-timeline" aria-label="MNS1 growth timeline">
        <div class="home-timeline__heading">
          <span>The road so far</span>
          <strong>Always forward.</strong>
        </div>
        <div class="home-timeline__items">
          <article><span>2011</span><strong>1</strong><p>Company inception, one truck, one driver, Plainfield, IL.</p></article>
          <article><span>2018</span><strong>100</strong><p>Trucks on the road, operations scaled across the Midwest.</p></article>
          <article><span>2024</span><strong>150</strong><p>Trucks, steady growth through Midwest lanes.</p></article>
          <article class="home-timeline__current"><span>Current</span><strong>180+</strong><p>Trucks, current fleet serving Midwest freight.</p></article>
        </div>
      </aside>
    </div>
  </section>

  <section class="section home-faq-section">
    <div class="wrap home-faq-grid">
      <div>
        <p class="eyebrow">Straight answers</p>
        <h2>Questions you're{" "}<br /><span>actually asking.</span></h2>
        <p>Short, honest answers. If you don't see yours, ask the recruiter on the call.</p>
        <div class="hero-actions">
          <CtaButton />
          <a class="button-secondary" href="tel:6302463280">630-246-3280</a>
        </div>
      </div>
      <div class="home-faq-list">
        <details open>
          <summary><span>01</span><strong>How fast can I start?</strong></summary>
          <p>Apply today, orient Monday. Most qualified drivers are seated in a truck within 7 days of first contact. Paid $200 orientation, lodging and travel covered.</p>
        </details>
        <details>
          <summary><span>02</span><strong>What CDL-A experience do you require?</strong></summary>
          <p>We hire drivers who have at least 2 years experience, valid CDL-A, DOT-qualifying driving record, and ability to pass DOT physical plus drug screen.</p>
        </details>
        <details>
          <summary><span>03</span><strong>How is pay calculated, exactly?</strong></summary>
          <p>Practical mile at your published per-mile rate. Detention after 2 hrs at $25/hr. Stop pay $35. Layover $150/day. Qualified drivers receive yearly pay raises. Weekly direct deposit every Friday.</p>
        </details>
        <details>
          <summary><span>04</span><strong>Can I bring my pet? Passenger?</strong></summary>
          <p>Yes to both. Pet policy: $500 non-refundable deposit, no breed restrictions, no weight limits. Spouse or partner ride-along approved on day 1. Passengers must be 18+.</p>
        </details>
        <details>
          <summary><span>05</span><strong>What does your safety score look like?</strong></summary>
          <p>All CSA scores are below intervention thresholds in all BASICs, resulting in a green ISS score. We turn down loads before we turn down a safety concern.</p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>
