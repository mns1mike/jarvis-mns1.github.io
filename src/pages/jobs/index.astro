---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import { jobMarkets } from "@data/jobs";

const states = Array.from(new Set(jobMarkets.map((market) => market.stateName)));
---

<BaseLayout title="CDL-A Regional Driver Jobs | MNS1 Express" description="MNS1 Express hires experienced CDL-A regional drivers for Midwest dry van, no-touch freight.">
  <PageHero
    eyebrow="CDL-A Regional Driver Jobs"
    title="Strong Miles During the Week. Home Where It Matters on the Weekend."
    lead="MNS1 Express hires experienced CDL-A regional drivers for Midwest dry van, no-touch freight. Top drivers average $1,650-$1,900+ gross per week with consistent miles, newer Freightliners, and real weekend home time."
  />
  <section class="section">
    <div class="wrap stat-grid">
      <article><strong>$1,650-$1,900+</strong><span>Top driver weekly gross</span></article>
      <article><strong>2,500-3,000</strong><span>Miles per week</span></article>
      <article><strong>Home weekends</strong><span>Regional Midwest lanes</span></article>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap section-heading">
      <p class="eyebrow">Available Markets</p>
      <h2>Job Directory by State</h2>
      <p>Choose a Midwest hiring state to see the matching local job pages.</p>
    </div>
    <div class="wrap grid grid--cards">
      {states.map((state) => {
        const markets = jobMarkets.filter((market) => market.stateName === state);
        return (
          <article class="card link-card">
            <h2>{state}</h2>
            <p>{markets.length} active local {markets.length === 1 ? "page" : "pages"}</p>
            {markets.map((market) => (
              <a class="text-link" href={`/jobs/${market.slug}/`}>{market.title.replace(" | MNS1 Express", "")}</a>
            ))}
          </article>
        );
      })}
    </div>
  </section>
  <section class="section">
    <div class="wrap section-heading">
      <p class="eyebrow">Driver Support</p>
      <h2>Benefits & Perks</h2>
      <p>A cleaner breakdown of what supports the driver personally and what keeps the operation moving during the week.</p>
    </div>
    <div class="wrap grid grid--cards">
      <article class="card"><h2>Personal Benefits</h2><ul class="check-list"><li>Medical, dental, and vision insurance</li><li>Company-paid life insurance</li><li>401(k) with company match</li><li>Paid time off and paid holidays</li><li>Employee Assistance Program</li><li>Paid weekly</li></ul></article>
      <article class="card"><h2>Operational Benefits</h2><ul class="check-list"><li>Pet and passenger program</li><li>Referral bonus opportunities</li><li>Detention, layover, and breakdown pay</li><li>Fuel cards, cash advances, and EFS checks</li><li>24/7 dispatch support</li><li>Roadside assistance</li></ul></article>
      <article class="card"><h2>Plainfield Terminal Perks</h2><ul class="check-list"><li>Driver lounge with bathrooms and showers</li><li>Laundry machines, TV, ice, and vending</li><li>On-site maintenance</li><li>Courtesy car access for drivers routed through the terminal</li></ul></article>
    </div>
  </section>
</BaseLayout>
