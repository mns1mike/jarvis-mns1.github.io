---
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";
import { benefitsSummary, driverBenefits, equipmentSummary, jobMarkets, perksSummary, requirementSummary } from "@data/jobs";
import BaseLayout from "@layouts/BaseLayout.astro";

export function getStaticPaths() {
  return jobMarkets.map((market) => ({
    params: { slug: market.slug },
    props: { market },
  }));
}

const { market } = Astro.props;
---

<BaseLayout title={market.title} description={market.description}>
  <PageHero eyebrow="CDL-A Driver Jobs" title={`CDL-A Driver Jobs in ${market.city}, ${market.state}`} lead={market.headline}>
    <div class="hero-actions">
      <CtaButton />
      <a class="button-secondary" href="/requirements/">View requirements</a>
    </div>
  </PageHero>

  <section class="section">
    <div class="wrap split">
      <div>
        <p>{market.description}</p>
        <h2>Job Snapshot</h2>
        <ul class="check-list">
          {driverBenefits.map((benefit) => <li>{benefit}</li>)}
        </ul>
        <h2>2023 or newer Freightliners</h2>
        <p>{equipmentSummary}</p>
        <h2>Benefits</h2>
        <p>{benefitsSummary}</p>
        <h2>Driver Perks</h2>
        <p>{perksSummary}</p>
      </div>
      <aside class="panel">
        <h3>Requirements</h3>
        <ul class="check-list">
          {requirementSummary.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>
