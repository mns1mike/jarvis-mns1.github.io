---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import CtaButton from "@components/CtaButton.astro";
import LaneMap from "@components/LaneMap.astro";
import { site } from "@data/site";

const hiringStates = [
  ["Illinois", "/jobs/#illinois"],
  ["Wisconsin", "/jobs/#wisconsin"],
  ["Minnesota", "/jobs/#minnesota"],
  ["Michigan", "/jobs/#michigan"],
  ["Ohio", "/jobs/#ohio"],
  ["Indiana", "/jobs/#indiana"],
  ["Iowa", "/jobs/#iowa"],
  ["Missouri", "/jobs/#missouri"],
  ["Kentucky", "/jobs/#kentucky"],
];

const cityMarkets = [
  ["Kansas City, KS", "/jobs/cdl-a-driver-kansas-city-ks/"],
  ["Omaha, NE", "/jobs/cdl-a-driver-omaha-ne/"],
];
---

<BaseLayout title="Midwest OTR Lanes & Hiring Area | MNS1 Express" description="We run the Midwest. Consistent lanes, predictable routes, and home time that works because your loads stay in our coverage area.">
  <PageHero
    eyebrow="Lanes & Coverage"
    title="OTR Midwest. No Southeast Surprises."
    accent="No Southeast Surprises."
    lead="We run the Midwest. Consistent lanes, predictable routes, and home time that works because your loads stay in our coverage area, not scattered across 48 states."
  >
    <div class="hero-actions">
      <CtaButton />
    </div>
  </PageHero>
  <section class="section section--panel">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Now Hiring From</p>
        <h2>13 Midwest States</h2>
      </div>
      <div class="grid grid--cards">
        {hiringStates.map(([state, href]) => (
          <a class="card link-card" href={href}>
            <svg class="icon icon--sm" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M21.8 10A10 10 0 1 1 17 3.3" />
              <path d="m9 11 3 3L22 4" />
            </svg>
            <h3>{state}</h3>
          </a>
        ))}
      </div>
      <div class="hero-actions">
        {cityMarkets.map(([city, href]) => (
          <a class="button-secondary" href={href}>
            <svg class="icon icon--sm" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M20 10c0 5-5.5 10.2-7.4 11.8a1 1 0 0 1-1.2 0C9.5 20.2 4 15 4 10a8 8 0 0 1 16 0" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            {city}
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Coverage Map</p>
        <h2>Where We Run</h2>
      </div>
      <LaneMap />
      <p class="lead-small">Interactive lane density map, coming soon</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap section-heading measure">
      <p class="eyebrow">Why Midwest Matters</p>
      <h2>Focused Lanes = Better Home Time</h2>
      <p>Mega carriers run you coast to coast and call it "flexibility." We call it chaos. MNS1 runs the Midwest because focused lanes mean predictable routes, consistent miles, and home time that actually works.</p>
      <p>When your loads stay in the coverage area, dispatch can plan your home date weeks in advance, not scramble to relay you back from Florida.</p>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap panel measure text-center">
      <h2>In Our Coverage Area?</h2>
      <p>CDL-A, 24+ months experience, based in one of our Midwest hiring areas. Apply in 4 mins.</p>
      <div class="hero-actions hero-actions--center">
        <CtaButton />
        <a class="button-secondary" href={site.phoneHref}>{site.phoneDisplay}</a>
      </div>
    </div>
  </section>
</BaseLayout>
