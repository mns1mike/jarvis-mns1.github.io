---
import BaseLayout from "@layouts/BaseLayout.astro";
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";
import { site } from "@data/site";

const iconStyle =
  "display:block;width:22px;height:22px;margin-bottom:14px;color:var(--color-blue);fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round";

const schedules = [
  {
    label: "Home every weekend",
    title: "1 Week Out",
    description: "Out Monday through Friday, home every weekend. Best for drivers close to Chicagoland who want maximum home time.",
  },
  {
    label: "Most popular schedule",
    title: "2 Weeks Out",
    description: "Two weeks on the road, then home for your 34-hour reset. A solid balance of miles and home time.",
    featured: true,
  },
  {
    label: "Maximum earning potential",
    title: "3 Weeks Out",
    description: "Three weeks out, then home for an extended reset. Maximum miles for drivers who want to stack paychecks.",
  },
];

const planningSteps = [
  ["calendar", "Choose Your Schedule", "1, 2, or 3 weeks out. You pick at orientation."],
  ["home", "Designated Saturday", "Home on your day for a full 34-hour reset."],
  ["clock", "Consistent Pattern", "Same rhythm every cycle. Plan your life around it."],
];

const reviews = [
  ["Sam A.", "I get home every Friday. When they say you'll be home, you're home. No excuses, no \"maybe next week.\" It's real."],
  ["Jon H.", "They do get you home every weekend. After two carriers that lied about home time, MNS1 actually delivers."],
];
---

<BaseLayout title="Home Every Weekend CDL-A Jobs | MNS1 Express" description="Choose 1, 2, or 3 weeks out, home on your designated Saturday for a full 34-hour reset.">
  <PageHero
    eyebrow="Home Time"
    title="Home When We Say You'll Be Home"
    accent="You'll Be Home"
    lead="Every carrier promises home time. We actually deliver it. Choose 1, 2, or 3 weeks out, home on your designated Saturday for a full 34-hour reset."
  >
    <div class="hero-actions">
      <CtaButton />
    </div>
  </PageHero>
  <section class="section">
    <div class="wrap section-heading">
      <p class="eyebrow">Flexible Schedules</p>
      <h2>Pick Your Rhythm</h2>
    </div>
    <div class="wrap grid grid--cards">
      {schedules.map((schedule) => (
        <article class="card" style={schedule.featured ? "border-color:var(--color-blue);box-shadow:0 30px 72px -40px rgba(0,153,215,.95)" : undefined}>
          <p class="eyebrow">{schedule.label}</p>
          <h2>{schedule.title}</h2>
          <p>{schedule.description}</p>
        </article>
      ))}
    </div>
  </section>
  <section class="section">
    <div class="wrap section-heading">
      <p class="eyebrow">How It Works</p>
      <h2>No Guessing Games</h2>
      <p>You pick your schedule at orientation. Dispatch builds your loads around your home date, not the other way around. Your designated Saturday is your designated Saturday. Period.</p>
    </div>
    <div class="wrap grid grid--cards">
      {planningSteps.map(([icon, title, description]) => (
        <article class="card">
          <svg aria-hidden="true" viewBox="0 0 24 24" style={iconStyle}>
            {icon === "calendar" && (
              <>
                <path d="M8 2v4" />
                <path d="M16 2v4" />
                <rect width="18" height="18" x="3" y="4" rx="2" />
                <path d="M3 10h18" />
              </>
            )}
            {icon === "home" && (
              <>
                <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
                <path d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
              </>
            )}
            {icon === "clock" && (
              <>
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </>
            )}
          </svg>
          <h3>{title}</h3>
          <p>{description}</p>
        </article>
      ))}
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap section-heading">
      <p class="eyebrow">From Real Drivers</p>
      <h2>Don't Take Our Word for It</h2>
    </div>
    <div class="wrap grid grid--cards">
      {reviews.map(([name, quote]) => (
        <article class="card">
          <svg aria-hidden="true" viewBox="0 0 24 24" style={iconStyle}>
            <path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z" />
            <path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z" />
          </svg>
          <p>"{quote}"</p>
          <p><strong>{name}</strong><br />MNS1 Driver</p>
        </article>
      ))}
    </div>
  </section>
  <section class="section">
    <div class="wrap section-heading">
      <p class="eyebrow">The Elephant in the Room</p>
      <h2>"Every Carrier Says That"</h2>
      <p>You're right, they do. And most of them are lying. You've probably been burned before. "Home every weekend" turns into "most weekends" which turns into "when we can."</p>
      <p>At MNS1, the owner is in the building and still in the trenches with the team. That day-to-day accountability is why the home time promise sticks.</p>
      <p>Five independent Google reviews confirm: the home time is real. Don't take our word for it, read them.</p>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap panel" style="max-width:640px;text-align:center">
      <h2>Ready to Get Home?</h2>
      <p>CDL-A, 24+ months experience. Apply in 4 mins and pick your home time schedule at orientation.</p>
      <div class="hero-actions" style="justify-content:center">
        <CtaButton />
        <a class="button-secondary" href={site.phoneHref}>{site.phoneDisplay}</a>
      </div>
    </div>
  </section>
</BaseLayout>
