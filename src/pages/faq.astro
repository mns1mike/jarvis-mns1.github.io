---
import BaseLayout from "@layouts/BaseLayout.astro";
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";

const questions = [
  {
    question: "How much does MNS1 pay?",
    answer: "Top drivers average $1,650-$1,900+ gross per week. Pay is built from miles, per diem structure, and accessorials like detention, stop pay, layover, and breakdown pay when applicable.",
  },
  {
    question: "How does home time work?",
    answer: "You choose the rhythm at orientation: 1, 2, or 3 weeks out. Dispatch plans around your designated Saturday so you can get a full 34-hour reset.",
  },
  {
    question: "What trucks do you run?",
    answer: "Every truck in the fleet is a 2023 or newer Freightliner Cascadia with automatic transmission, eAPU, inverter, refrigerator, microwave, Bluetooth, and double bunk sleeper.",
  },
  {
    question: "What's the pet policy?",
    answer: "Pets are allowed with a $500 non-refundable deposit. No breed restrictions and no weight limits.",
  },
  {
    question: "Can I bring a rider?",
    answer: "Yes. Spouse or partner ride-along is approved on day one. Passengers must be 18 or older.",
  },
  {
    question: "What happens at orientation?",
    answer: "Orientation is two days at the Plainfield, IL terminal. Bring your CDL, current DOT medical card, Social Security card, and voided check for direct deposit.",
  },
  {
    question: "Are there inward-facing cameras?",
    answer: "No. Dash cameras face outward for road protection. There is no inward-facing lens watching the cab.",
  },
  {
    question: "Is dispatch forced?",
    answer: "Dispatch works the Midwest lanes MNS1 knows and plans around your home-time choice. You get consistent dry van freight without surprise southeast or coast-to-coast dispatch.",
  },
  {
    question: "How long does the application take?",
    answer: "The quick apply takes about 4 minutes. A real recruiter follows up directly; no bots and no robocalls.",
  },
];
---

<BaseLayout title="CDL-A Driver FAQ | MNS1 Express" description="Everything drivers ask before applying, pay, home time, equipment, policies. No fluff, no dodging. Real answers.">
  <PageHero
    eyebrow="FAQ"
    title="Questions? Answers."
    lead="Everything drivers ask before applying, pay, home time, equipment, policies. No fluff, no dodging. Real answers."
    centered
  />
  <section class="section section--flush-top">
    <div class="wrap faq-list">
      {questions.map((item) => (
        <details class="faq-card panel">
          <summary>
            <h2>{item.question}</h2>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap panel">
      <h2>Still Have Questions?</h2>
      <p>Reach recruiting directly. Real person, real answers. Or apply and they'll reach out within 24 hours.</p>
      <div class="hero-actions">
        <CtaButton />
        <a class="button-secondary" href="tel:6302463280">630-246-3280</a>
      </div>
    </div>
  </section>
</BaseLayout>
