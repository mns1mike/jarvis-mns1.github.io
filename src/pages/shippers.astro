---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
---

<BaseLayout title="Midwest Dry Van Trucking & Drop Trailers | MNS1 Express" description="MNS1 Express provides reliable dry van capacity across 16 Midwest states. Asset-based, company-owned fleet — no brokered trucks, no surprises.">
  <PageHero
    eyebrow="For Shippers"
    title="Midwest Dry Van Coverage. 180+ Trucks."
    accent="180+ Trucks."
    lead="MNS1 Express provides reliable dry van capacity across 16 Midwest states. Asset-based, company-owned fleet — no brokered trucks, no surprises."
  >
    <div class="hero-actions">
      <a class="button-secondary" href="/contact/">Request a Quote</a>
      <a class="button-secondary" href="mailto:info@mns1express.com">Email Us</a>
    </div>
  </PageHero>
  <section class="section">
    <div class="wrap section-heading">
      <p class="eyebrow">Capabilities</p>
      <h2>What We Haul</h2>
    </div>
    <div class="wrap grid grid--cards">
      <article class="card"><h2>Dry Van</h2><p>53' dry van trailers — Great Dane and Utility. Standard, reliable, well-maintained.</p></article>
      <article class="card"><h2>No-Touch Freight</h2><p>Driver stays in the cab. No loading, no unloading. Clean cargo handled by the shipper/receiver.</p></article>
      <article class="card"><h2>Asset-Based Fleet</h2><p>180+ company-owned trucks. No brokered capacity — every load moves on our equipment with our drivers.</p></article>
      <article class="card"><h2>16-State Coverage</h2><p>16-state Midwest coverage — plus Kansas City and Omaha. Dense Midwest network.</p></article>
      <article class="card"><h2>On-Time Performance</h2><p>Consistent lanes, professional drivers, and dispatch that plans ahead. We show up when we say we will.</p></article>
      <article class="card"><h2>Since 2011</h2><p>Family-owned and operated from Plainfield, IL. Built on reputation, not marketing spend.</p></article>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap stat-grid">
      <article><strong>180+</strong><span>Company trucks</span></article>
      <article><strong>400+</strong><span>Dry van trailers</span></article>
      <article><strong>16</strong><span>Midwest states</span></article>
      <article><strong>2011</strong><span>Established</span></article>
    </div>
  </section>
  <section class="section">
    <div class="wrap split">
      <div>
        <p class="eyebrow">Why MNS1</p>
        <h2>What Sets Us Apart</h2>
        <ul class="check-list">
          <li>Asset-based — no brokered loads, no third-party carriers</li>
          <li>2023+ Freightliner fleet with GPS tracking</li>
          <li>Consistent lane coverage across the Midwest</li>
          <li>Single point of contact for capacity planning</li>
          <li>Family-owned with direct access to operations leadership</li>
          <li>Competitive rates backed by fleet efficiency</li>
        </ul>
      </div>
      <aside class="panel">
        <p class="eyebrow">Coverage Area</p>
        <h3>Dense Midwest Network</h3>
        <p>Our fleet operates across 16 Midwest states, with extensions into Kansas City and Omaha. Focused coverage means consistent capacity where you need it.</p>
      </aside>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap panel">
      <h2>Need Midwest Capacity?</h2>
      <p>Contact us for rates and availability. Direct line to our freight team — no call center, no runaround.</p>
      <p><a class="text-link" href="mailto:info@mns1express.com">Email for Rates</a></p>
    </div>
  </section>
</BaseLayout>
