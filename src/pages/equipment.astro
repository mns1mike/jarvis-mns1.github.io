---
import BaseLayout from "@layouts/BaseLayout.astro";
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";
import { site } from "@data/site";

const iconStyle =
  "display:block;width:22px;height:22px;margin-bottom:14px;color:var(--color-blue);fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round";

const equipmentFeatures = [
  {
    title: "Automatic Transmission",
    description: "Detroit D15 engines with automatic transmission. Focus on driving, not shifting.",
    paths: ["M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2", "M15 18H9", "M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"],
  },
  {
    title: "eAPU Park-Smart",
    description: "Full climate control without idling. Heat, AC, and power all night — 7-minute idle policy means the eAPU does the work.",
    paths: ["M12.8 19.6A2 2 0 1 0 14 16H2", "M17.5 8a2.5 2.5 0 1 1 2 4H2", "M9.8 4.4A2 2 0 1 1 11 8H2"],
  },
  {
    title: "Full Kitchen Setup",
    description: "Built-in refrigerator, microwave, and inverter. Eat real food, save money, stay comfortable on the road.",
    paths: ["M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"],
  },
  {
    title: "Entertainment",
    description: "Sirius XM satellite radio and Bluetooth connectivity. Thousands of channels for the long haul.",
    paths: ["M4.9 19.1C1 15.2 1 8.8 4.9 4.9", "M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5", "M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5", "M19.1 4.9C23 8.8 23 15.1 19.1 19"],
  },
  {
    title: "Outward-Only Cameras",
    description: "Your cab is your home. Cameras face the road, never you. No inward-facing cameras — period.",
    paths: ["M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"],
  },
  {
    title: "Double Bunk Sleeper",
    description: "Spacious double bunk sleeper. Room for you, your gear, and your co-pilot (pet or rider).",
    paths: ["M2 4v16", "M2 8h18a2 2 0 0 1 2 2v10", "M2 17h20", "M6 8v9"],
  },
  {
    title: "CoPilot Navigation",
    description: "Company-provided truck navigation on the tablet, built for truck routes and dispatch consistency.",
    paths: ["M12 2v20", "M2 12h20", "m16 8 4 4-4 4", "m8 8-4 4 4 4"],
  },
  {
    title: "DriveWyze Bypass",
    description: "Weight station bypass device to help qualified drivers keep rolling instead of burning time in line.",
    paths: ["M20 6 9 17l-5-5", "M4 6h16", "M4 18h16"],
  },
];

const trailerSpecs = [
  ["Trailer Type", "53' Dry Van"],
  ["Brands", "Great Dane & Utility"],
  ["Tandem Slide", "Push-Button"],
  ["ATIS", "Automatic Tire Inflation"],
  ["Freight Type", "No-Touch"],
];
---

<BaseLayout title="2023+ Freightliner Cascadia Trucks | MNS1 Express" description="Every truck in the MNS1 fleet is a 2023 or newer Freightliner Cascadia — fully loaded, automatic, double bunk.">
  <PageHero
    eyebrow="Equipment"
    title="2023+ Freightliners. The Whole Fleet."
    accent="The Whole Fleet."
    lead={'Not "select trucks." Not "when available." Every truck in the MNS1 fleet is a 2023 or newer Freightliner Cascadia — fully loaded, automatic, double bunk.'}
  >
    <div class="hero-actions">
      <CtaButton />
    </div>
  </PageHero>
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Freightliner Cascadia</p>
      <h2>Your Truck, Your Home</h2>
      <div class="grid grid--cards">
        {equipmentFeatures.map((feature) => (
          <article class="card">
            <svg aria-hidden="true" viewBox="0 0 24 24" style={iconStyle}>
              {feature.paths.map((path) => <path d={path} />)}
              {feature.title === "Automatic Transmission" && (
                <>
                  <circle cx="17" cy="18" r="2" />
                  <circle cx="7" cy="18" r="2" />
                </>
              )}
              {feature.title === "Entertainment" && <circle cx="12" cy="12" r="2" />}
              {feature.title === "Outward-Only Cameras" && <circle cx="12" cy="13" r="3" />}
            </svg>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Trailers</p>
        <h2>53' Dry Vans — Great Dane & Utility</h2>
        <p>Our trailer fleet runs 53' Great Dane and Utility dry vans with push-button tandem slide. Well-maintained, clean, and road-ready. No-touch freight means you move the trailer, not the cargo.</p>
      </div>
      <div class="grid grid--cards">
        {trailerSpecs.map(([label, value]) => (
          <article class="card">
            <p class="eyebrow">{label}</p>
            <h3>{value}</h3>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="wrap section-heading">
      <p class="eyebrow">Driver Policies</p>
      <h2>Policies That Respect Drivers</h2>
    </div>
    <div class="wrap grid grid--cards">
      <article class="card"><h2>Governed at 70 MPH</h2><p>Fast enough to be competitive, governed for safety and fuel efficiency.</p></article>
      <article class="card"><h2>7-Minute Idle Policy</h2><p>The eAPU handles climate control. You'll rarely need to idle — and when you do, you get 7 minutes, not 3.</p></article>
      <article class="card"><h2>Never Need Chains</h2><p>Our routes and dispatching mean you never need to chain up. We route around it.</p></article>
      <article class="card"><h2>Outward-Only Cameras</h2><p>Dash cameras face the road for your protection. No inward lens watching your cab.</p></article>
    </div>
  </section>
  <section class="section">
    <div class="wrap panel">
      <h2>Drive New Iron</h2>
      <p>CDL-A, 24+ months experience. Apply in 4 mins and see the fleet for yourself at orientation.</p>
      <div class="hero-actions">
        <CtaButton />
        <a class="button-secondary" href={site.phoneHref}>{site.phoneDisplay}</a>
      </div>
    </div>
  </section>
</BaseLayout>
