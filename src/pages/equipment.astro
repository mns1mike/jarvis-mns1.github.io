---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
---

<BaseLayout title="2023+ Freightliner Cascadia Trucks | MNS1 Express" description="Every truck in the MNS1 fleet is a 2023 or newer Freightliner Cascadia — fully loaded, automatic, double bunk.">
  <PageHero
    eyebrow="Equipment"
    title="2023+ Freightliners. The Whole Fleet."
    lead={'Not "select trucks." Not "when available." Every truck in the MNS1 fleet is a 2023 or newer Freightliner Cascadia — fully loaded, automatic, double bunk.'}
  />
  <section class="section">
    <div class="wrap split">
      <div>
        <p class="eyebrow">Freightliner Cascadia</p>
        <h2>Your Truck, Your Home</h2>
        <div class="grid grid--cards">
          <article class="card"><h3>Automatic Transmission</h3><p>Detroit D15 engines with automatic transmission. Focus on driving, not shifting.</p></article>
          <article class="card"><h3>eAPU Park-Smart</h3><p>Full climate control without idling. Heat, AC, and power all night — 7-minute idle policy means the eAPU does the work.</p></article>
          <article class="card"><h3>Full Kitchen Setup</h3><p>Built-in refrigerator, microwave, and inverter. Eat real food, save money, stay comfortable on the road.</p></article>
          <article class="card"><h3>Entertainment</h3><p>Sirius XM satellite radio and Bluetooth connectivity. Thousands of channels for the long haul.</p></article>
          <article class="card"><h3>Outward-Only Cameras</h3><p>Your cab is your home. Cameras face the road, never you. No inward-facing cameras — period.</p></article>
          <article class="card"><h3>Double Bunk Sleeper</h3><p>Spacious double bunk sleeper. Room for you, your gear, and your co-pilot (pet or rider).</p></article>
          <article class="card"><h3>CoPilot Navigation</h3><p>Company-provided truck navigation on the tablet, built for truck routes and dispatch consistency.</p></article>
          <article class="card"><h3>DriveWyze Bypass</h3><p>Weight station bypass device to help qualified drivers keep rolling instead of burning time in line.</p></article>
        </div>
      </div>
      <aside class="panel">
        <p class="eyebrow">Trailers</p>
        <h3>53' Dry Vans — Great Dane & Utility</h3>
        <p>Our trailer fleet runs 53' Great Dane and Utility dry vans with push-button tandem slide. Well-maintained, clean, and road-ready. No-touch freight means you move the trailer, not the cargo.</p>
        <ul class="check-list">
          <li>Trailer Type: 53' Dry Van</li>
          <li>Brands: Great Dane & Utility</li>
          <li>Tandem Slide: Push-Button</li>
          <li>ATIS: Automatic Tire Inflation</li>
          <li>Freight Type: No-Touch</li>
        </ul>
      </aside>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap grid grid--cards">
      <article class="card"><h2>Governed at 70 MPH</h2><p>Fast enough to be competitive, governed for safety and fuel efficiency.</p></article>
      <article class="card"><h2>7-Minute Idle Policy</h2><p>The eAPU handles climate control. You'll rarely need to idle — and when you do, you get 7 minutes, not 3.</p></article>
      <article class="card"><h2>Never Need Chains</h2><p>Our routes and dispatching mean you never need to chain up. We route around it.</p></article>
      <article class="card"><h2>Dash cameras face the road for your protection.</h2><p>No inward lens watching your cab.</p></article>
    </div>
  </section>
  <section class="section">
    <div class="wrap panel">
      <h2>Drive New Iron</h2>
      <p>CDL-A, 24+ months experience. Apply in 4 mins and see the fleet for yourself at orientation.</p>
      <p><a class="text-link" href="tel:6302463280">630-246-3280</a></p>
    </div>
  </section>
</BaseLayout>
