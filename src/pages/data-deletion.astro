---
import LegalArticle from "@components/LegalArticle.astro";
import { legalPages } from "@data/legalPages";
import BaseLayout from "@layouts/BaseLayout.astro";

const page = legalPages.find((item) => item.slug === "data-deletion")!;
---

<BaseLayout title={`${page.title} | MNS1 Express`} description={page.description}>
  <LegalArticle page={page} />
</BaseLayout>
