---
import BaseLayout from "@layouts/BaseLayout.astro";
import PageHero from "@components/PageHero.astro";
import { blogPosts } from "@data/blog";
---

<BaseLayout title="MNS1 Express Blog" description="CDL-A driver and Midwest trucking guides from MNS1 Express.">
  <PageHero
    eyebrow="MNS1 Express Blog"
    title="Driver Guides"
    lead="Short, practical articles for experienced drivers comparing pay, home time, equipment, lanes, and carrier fit."
  />
  <section class="section">
    <div class="wrap section-heading">
      <h2 style="font-size:44px;margin-bottom:24px">Latest Articles</h2>
    </div>
    <div class="wrap grid grid--cards">
      {blogPosts.map((post) => (
        <a class="card link-card" href={`/blog/${post.slug}/`}>
          <p class="eyebrow">{post.category}</p>
          <h2>{post.title}</h2>
          <p>{post.description}</p>
        </a>
      ))}
    </div>
  </section>
  <section class="section">
    <div class="wrap panel">
      <h2>Don't Wait for the Blog</h2>
      <p>Have a question before applying? Reach MNS1 Express recruiting or start the driver application directly.</p>
      <div class="hero-actions">
        <a class="cta-button" href="https://intelliapp.driverapponline.com/c/mns1express?r=CompanyWebsite"><span>Apply in 4 mins</span><span aria-hidden="true">-&gt;</span></a>
        <a class="button-secondary" href="tel:6302463280">Call 630-246-3280</a>
      </div>
    </div>
  </section>
</BaseLayout>
