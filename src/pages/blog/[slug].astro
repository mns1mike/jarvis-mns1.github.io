---
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";
import { blogPosts } from "@data/blog";
import BaseLayout from "@layouts/BaseLayout.astro";

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BaseLayout title={`${post.title} | MNS1 Express`} description={post.description}>
  <PageHero eyebrow={post.category} title={post.title} lead={post.description} />

  <article class="article wrap">
    <p class="muted">{post.readingMinutes} min read</p>
    {post.sections.map((section) => (
      <section>
        <h2>{section.heading}</h2>
        <p>{section.body}</p>
      </section>
    ))}
    <aside class="panel">
      <h2>Ask recruiting</h2>
      <div class="hero-actions">
        <CtaButton />
        <a class="button-secondary" href="/blog/">Back to blog</a>
      </div>
    </aside>
  </article>
</BaseLayout>
