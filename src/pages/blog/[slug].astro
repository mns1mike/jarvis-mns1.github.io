---
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const blogPosts = await getCollection("blog");
  return blogPosts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | MNS1 Express`} description={post.data.description}>
  <PageHero eyebrow={post.data.category} title={post.data.title} lead={post.data.description} />

  <article class="article wrap">
    <p class="muted">{post.data.readingMinutes} min read</p>
    <Content />
    <div class="hero-actions">
      <CtaButton />
      <a class="button-secondary" href="/blog/">Back to blog</a>
      <a class="button-secondary" href="/contact/">Ask recruiting</a>
    </div>
  </article>
</BaseLayout>
