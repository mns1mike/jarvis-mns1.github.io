---
import BaseLayout from "@layouts/BaseLayout.astro";
import CtaButton from "@components/CtaButton.astro";
import PageHero from "@components/PageHero.astro";
import { site } from "@data/site";

const philosophyCards = [
  {
    title: "Always Forward",
    description:
      "Our brand is an arrow. We don't look back — we improve, adapt, and move. Every decision pushes us forward.",
  },
  {
    title: "Driver-First Decisions",
    description:
      "Equipment, pay, home time, policies — we make choices from the driver's seat. If it doesn't work for drivers, it doesn't work for us.",
  },
  {
    title: "The Explorer Archetype",
    description:
      "We're not the biggest. We're the ones willing to explore new territory — in technology, in operations, in how a carrier should treat its people.",
  },
  {
    title: "No Shortcuts",
    description:
      "180+ trucks built without cutting corners on safety, equipment, or people. The plan to 500 follows the same playbook.",
  },
];
---

<BaseLayout
  title="About MNS1 Express | Plainfield, IL Midwest Carrier"
  description="Family-owned since 2011, MNS1 Express has grown from one truck into a 180+ truck Midwest carrier built on fair driver treatment and shipper accountability."
>
  <PageHero
    eyebrow="About MNS1 Express"
    title="One Truck. One Driver. One Vision."
    lead="Founded in 2011 with a single truck in Chicagoland. Today: 180+ trucks, 11 Midwest states, and a Plainfield HQ — still family-owned, still driver-first."
  />
  <section class="section">
    <div class="wrap stat-grid stat-grid--icons">
      <article style="text-align:center">
        <svg aria-hidden="true" viewBox="0 0 24 24" style="display:block;width:22px;height:22px;margin:0 auto 12px;color:var(--color-blue);fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round">
          <path d="M8 2v4" />
          <path d="M16 2v4" />
          <rect width="18" height="18" x="3" y="4" rx="2" />
          <path d="M3 10h18" />
        </svg>
        <strong>2011</strong><span>Founded</span>
      </article>
      <article style="text-align:center">
        <svg aria-hidden="true" viewBox="0 0 24 24" style="display:block;width:22px;height:22px;margin:0 auto 12px;color:var(--color-blue);fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round">
          <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2" />
          <path d="M15 18H9" />
          <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.62l-3.48-4.35A1 1 0 0 0 17.52 8H14" />
          <circle cx="17" cy="18" r="2" />
          <circle cx="7" cy="18" r="2" />
        </svg>
        <strong>180+</strong><span>Trucks today</span>
      </article>
      <article style="text-align:center">
        <svg aria-hidden="true" viewBox="0 0 24 24" style="display:block;width:22px;height:22px;margin:0 auto 12px;color:var(--color-blue);fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round">
          <circle cx="12" cy="12" r="10" />
          <circle cx="12" cy="12" r="6" />
          <circle cx="12" cy="12" r="2" />
        </svg>
        <strong>500</strong><span>Target fleet size</span>
      </article>
      <article style="text-align:center">
        <svg aria-hidden="true" viewBox="0 0 24 24" style="display:block;width:22px;height:22px;margin:0 auto 12px;color:var(--color-blue);fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round">
          <path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0Z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        <strong>11</strong><span>Midwest states</span>
      </article>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <div style="max-width:720px">
        <div class="section-heading">
          <p class="eyebrow">Our Story</p>
          <h2>From One Truck to 180+</h2>
        </div>
        <div style="display:flex;flex-direction:column;gap:20px;color:var(--color-muted);line-height:1.8">
          <p style="margin:0">Mike founded MNS1 Express in 2011 with a single truck in the Chicago suburbs. No investors, no fleet manager — just a driver who believed he could do it better.</p>
          <p style="margin:0">That one truck became two. Then ten. Then fifty. Each step was built on the same principle: treat drivers the way you'd want to be treated. Pay fairly. Keep your promises on home time. Run good equipment. Don't cut corners.</p>
          <p style="margin:0">In 2023, MNS1 moved to its current headquarters at <strong style="color:#fff">14458 S Depot Dr, Plainfield, IL 60544</strong> — a purpose-built facility with room to grow. The fleet now runs 180+ trucks across 11 Midwest states, with a target of 500.</p>
          <p style="margin:0">Mike is still in the building. Not a figurehead — an operator. IT professional with 14+ years of infrastructure experience who brings that engineering mindset to every part of the business: systems, processes, decisions.</p>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Philosophy</p>
        <h2>1% Better Every Day</h2>
      </div>
      <div class="grid grid--cards">
        {philosophyCards.map((card) => (
          <article class="card">
            <h2>{card.title}</h2>
            <p>{card.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Headquarters</p>
        <h2>Plainfield, Illinois</h2>
      </div>
      <div class="panel" style="max-width:500px">
        <div style="display:flex;align-items:flex-start;gap:14px">
          <svg aria-hidden="true" viewBox="0 0 24 24" style="width:20px;height:20px;margin-top:3px;color:var(--color-blue);fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0">
            <path d="M20 10c0 5-5.5 10.2-7.4 11.8a1 1 0 0 1-1.2 0C9.5 20.2 4 15 4 10a8 8 0 0 1 16 0" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <p style="margin:0;color:var(--color-muted);line-height:1.8">
            <strong style="color:#fff">MNS1 Express Inc.</strong><br />
            {site.addressLines[0]}<br />
            {site.addressLines[1]}<br />
            <a class="text-link" href={site.phoneHref}>{site.phoneDisplay}</a>
          </p>
        </div>
      </div>
    </div>
  </section>
  <section class="section section--panel">
    <div class="wrap section-heading" style="max-width:600px;text-align:center;margin-bottom:0">
      <h2>Join the MNS1 Team</h2>
      <p>CDL-A, 24+ months experience. Apply in 4 mins. Orientation in Plainfield.</p>
      <div class="hero-actions" style="justify-content:center">
        <CtaButton />
        <a class="button-secondary" href={site.phoneHref}>
          <svg aria-hidden="true" viewBox="0 0 24 24" style="width:18px;height:18px;margin-right:8px;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.18 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.72c.1.95.34 1.88.7 2.81a2 2 0 0 1-.45 2.11L8.1 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.93.36 1.86.6 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          {site.phoneDisplay}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
