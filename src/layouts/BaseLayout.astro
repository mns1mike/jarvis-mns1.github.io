---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import MobileCta from "@components/MobileCta.astro";
import { site } from "@data/site";
import "@styles/global.css";

type Props = {
  title: string;
  description: string;
  robots?: string;
  keywords?: string;
  preloadHero?: boolean;
};

const {
  title,
  description,
  robots = "index, follow",
  keywords = "CDL-A jobs, truck driver jobs, OTR trucking, Midwest trucking, MNS1 Express, Plainfield IL",
  preloadHero = false,
} = Astro.props;
const canonicalPath = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalUrl = new URL(canonicalPath, site.url).toString();
const preloadImage = preloadHero ? "/images/site/mns1-terminal-hero.jpg" : site.logoPath;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content={robots} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    <link rel="icon" href="/images/logo/mns1-logo-transparent.png" />
    <slot name="head" />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        name: site.name,
        url: site.url,
        logo: new URL(site.logoPath, site.url).toString(),
        description: "Midwest CDL-A carrier. 180+ trucks. Founded 2011. Headquartered in Plainfield, IL.",
        address: {
          "@type": "PostalAddress",
          streetAddress: site.addressLines[0],
          addressLocality: "Plainfield",
          addressRegion: "IL",
          postalCode: "60544",
          addressCountry: "US",
        },
        telephone: "+1-630-246-3280",
        foundingDate: "2011",
        sameAs: [
          "https://www.facebook.com/mns1express/",
          "https://www.instagram.com/mns1exp/",
          "https://www.linkedin.com/company/28994033/",
        ],
      })}
    />
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
      <MobileCta />
    </div>
  </body>
</html>
