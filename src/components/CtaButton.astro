---
import { site } from "@data/site";

type Props = {
  href?: string;
  label?: string;
  class?: string;
};

const { href = site.applyUrl, label = "Apply in 4 mins", class: className = "" } = Astro.props;
const isApplyCta = href === site.applyUrl;
---

<a class={`cta-button ${isApplyCta ? "cta-button--liquid" : ""} ${className}`} href={href}>
  <span>{label}</span><span aria-hidden="true">-></span>
</a>

<style>
  .cta-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
    isolation: isolate;
    min-width: var(--header-cta-width);
    min-height: var(--header-cta-height);
    padding: 9px 14px;
    gap: 10px;
    border: 1px solid rgb(var(--a)/.95);
    border-radius: var(--radius-control);
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-cta) 54%, var(--color-accent-hover) 100%);
    box-shadow:
      0 12px 30px -10px rgb(var(--a)/.95),
      0 0 0 1px rgb(var(--i)/.18) inset,
      0 0 30px -13px rgb(var(--a)/.72);
    color: var(--color-ink);
    font: 700 13px/1 var(--font-body);
    letter-spacing: 0.02em;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 180ms cubic-bezier(0.2, 0.7, 0.2, 1), box-shadow 180ms, filter 180ms;
  }

  .cta-button::before {
    position: absolute;
    inset: -2px;
    z-index: 0;
    border-radius: inherit;
    padding: 2px;
    background: linear-gradient(105deg, rgb(var(--a)/.16), rgb(var(--i)/.92) 18%, rgb(var(--a)/.18) 46%, rgb(var(--i)/.74) 66%, rgb(var(--a)/.9) 78%, rgb(var(--a)/.16));
    background-position: 0% 50%;
    background-size: 240% 100%;
    content: "";
    mask: linear-gradient(var(--color-ink) 0 0) content-box, linear-gradient(var(--color-ink) 0 0);
    mask-composite: exclude;
    pointer-events: none;
  }

  .cta-button::after {
    position: absolute;
    inset: -5px;
    z-index: -1;
    border-radius: calc(var(--radius-control) + 3px);
    background: linear-gradient(105deg, rgb(var(--a)/0), rgb(var(--a)/.72), rgb(var(--i)/.54), rgb(var(--a)/.16), rgb(var(--a)/0));
    background-position: 0% 50%;
    background-size: 240% 100%;
    content: "";
    filter: blur(8px);
    opacity: 0;
    pointer-events: none;
  }

  .cta-button--liquid::before {
    animation: mns1-liquid-outline 4.8s ease-in-out infinite;
  }

  .cta-button--liquid::after {
    animation: mns1-liquid-outline 4.8s ease-in-out infinite, mns1-liquid-bloom 2.8s ease-in-out infinite;
  }

  .cta-button > span {
    position: relative;
    z-index: 1;
  }

  .cta-button:hover {
    transform: translateY(-1px);
    box-shadow:
      0 18px 38px -12px rgb(var(--a)/1),
      0 0 0 1px rgb(var(--i)/.2) inset,
      0 0 36px -12px rgb(var(--a)/.82);
  }

  @keyframes mns1-liquid-outline {
    50% {
      background-position: 100% 50%;
    }
  }

  @keyframes mns1-liquid-bloom {
    45% {
      opacity: .58;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-button--liquid::before,
    .cta-button--liquid::after {
      animation: none;
    }
  }
</style>
