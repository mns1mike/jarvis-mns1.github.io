---
import { site } from "@data/site";

const applyUrl = new URL(site.applyUrl);
---

<div class="mobile-cta" aria-label="Quick contact actions">
  <form action={applyUrl.origin + applyUrl.pathname} method="get">
    <input type="hidden" name="r" value={applyUrl.searchParams.get("r") ?? "CompanyWebsite"} />
    <button type="submit">Apply in 4 mins <span aria-hidden="true">-&gt;</span></button>
  </form>
  <a href={site.phoneHref}>Call</a>
</div>

<style is:global>
  .mobile-cta{display:none}
  @media(max-width:768px){
    .mobile-cta{position:fixed;inset:auto 0 0;z-index:50;display:flex;gap:10px;padding:10px 12px calc(10px + env(safe-area-inset-bottom));border-top:1px solid var(--color-line);background:var(--color-canvas)}
    .mobile-cta form{flex:1}
    .mobile-cta button,.mobile-cta a{display:grid;min-height:46px;place-items:center;border-radius:var(--radius-control);font:800 13px/1 var(--font-body);text-decoration:none}
    .mobile-cta button{width:100%;border:0;background:var(--color-blue);color:#fff}
    .mobile-cta a{width:92px;border:1px solid var(--color-surface-strong);color:#fff}
  }
</style>
