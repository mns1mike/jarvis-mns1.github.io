---
import CtaButton from "@components/CtaButton.astro";
import { primaryNav } from "@data/navigation";
import { site } from "@data/site";

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href);
};
---

<header class="site-header" data-site-header>
  <div class="topbar">
    <div class="topbar__inner">
      <span class="topbar__left">
        <span>{site.tagline}</span>
        <span aria-hidden="true">·</span>
        <span>Plainfield, IL · 180+ trucks · 16 states</span>
      </span>
      <span class="topbar__right">
        <a href="/contact/">Contact</a>
        <a href="/faq/">FAQ</a>
        <a href={site.phoneHref}>{site.phoneDisplay}</a>
      </span>
    </div>
  </div>
  <div class="navrow">
    <a class="brand" href="/" aria-label="MNS1 Express home">
      <img src={site.logoPath} alt="MNS1 Express" width="102" height="102" />
    </a>
    <details class="mobile-nav">
      <summary class="mobile-menu" aria-label="Menu">
        <span aria-hidden="true">&#9776;</span>
      </summary>
    </details>
    <nav class="primary-nav" aria-label="Primary">
      {primaryNav.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
    <CtaButton class="header-cta" />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    height: calc(var(--header-topbar-height) + var(--header-row-height) + 1px);
    border-bottom: 1px solid transparent;
    background: transparent;
  }

  .topbar {
    height: var(--header-topbar-height);
    overflow: hidden;
    border-bottom: 1px solid var(--color-line-soft);
    background: rgb(var(--c)/.42);
  }

  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: min(100%, var(--site-max));
    height: 32px;
    margin: 0 auto;
    padding: 8px 24px;
    color: var(--color-dim);
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  .topbar__left,
  .topbar__right {
    display: flex;
    align-items: center;
    gap: 14px;
    white-space: nowrap;
  }

  .topbar__left span:first-child {
    color: var(--color-muted);
    font-weight: 600;
  }

  .topbar a {
    color: var(--color-dim);
    text-decoration: none;
  }

  .topbar a[href^="tel:"] {
    color: var(--color-blue);
    font-weight: 700;
  }

  .navrow {
    position: relative;
    display: flex;
    align-items: center;
    gap: 32px;
    width: min(100%, var(--site-max));
    height: var(--header-row-height);
    margin: 0 auto;
    padding: 14px 24px;
  }

  .brand {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
    text-decoration: none;
  }

  .brand img {
    display: block;
    width: auto;
    height: var(--header-logo-height);
  }

  .primary-nav {
    display: flex;
    flex: 1 1 0;
    align-items: center;
    gap: var(--header-nav-gap);
    min-width: 0;
    margin-left: 12px;
  }

  .primary-nav a {
    display: inline-flex;
    align-items: center;
    height: var(--header-nav-link-height);
    padding: 6px 0;
    border-bottom: 2px solid transparent;
    color: var(--color-muted);
    font-size: var(--header-nav-font-size);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .primary-nav a[aria-current="page"],
  .primary-nav a:hover {
    color: var(--color-blue);
    border-bottom-color: var(--color-blue);
  }

  .mobile-nav {
    display: none;
  }

  @media (max-width: 768px) {
    .site-header {
      height: 73px;
    }

    .topbar,
    .primary-nav {
      display: none;
    }

    .navrow {
      width: min(100%, var(--site-max));
      height: 72px;
      padding: 14px 24px;
    }

    .site-header :global(.header-cta.cta-button) {
      display: none;
    }

    .mobile-nav {
      position: relative;
      display: block;
      margin-left: auto;
    }

    .mobile-menu {
      display: grid;
      width: 44px;
      height: 44px;
      place-items: center;
      border: 0;
      background: transparent;
      color: var(--color-ink);
      cursor: pointer;
      font: 800 26px/1 var(--font-body);
      list-style: none;
    }

    .mobile-menu::-webkit-details-marker {
      display: none;
    }

    .mobile-nav[open] + .primary-nav {
      position: absolute;
      top: 54px;
      right: 0;
      display: grid;
      width: min(300px, calc(100vw - 48px));
      margin-left: 0;
      padding: 8px;
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      background: var(--color-canvas);
    }

    .mobile-nav[open] + .primary-nav a {
      display: flex;
      min-height: 44px;
      align-items: center;
      padding: 0 12px;
      color: var(--color-muted);
      font-weight: 700;
      text-decoration: none;
    }
  }
</style>
