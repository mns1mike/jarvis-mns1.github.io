---
type Props = {
  eyebrow: string;
  title: string;
  lead: string;
};

const { eyebrow, title, lead } = Astro.props;
---

<section class="hero page-hero">
  <div class="wrap">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="display-title">{title}</h1>
    <p class="lead">{lead}</p>
    <slot />
  </div>
</section>
