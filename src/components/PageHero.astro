---
type Props = {
  eyebrow: string;
  title: string;
  lead: string;
  accent?: string;
  centered?: boolean;
};

const { eyebrow, title, lead, accent, centered = false } = Astro.props;
const accentIndex = accent ? title.indexOf(accent) : -1;
const beforeAccent = accentIndex >= 0 ? title.slice(0, accentIndex).trimEnd() : title;
const afterAccent = accentIndex >= 0 ? title.slice(accentIndex + accent.length).trimStart() : "";
---

<section class:list={["hero", "page-hero", { "text-center": centered }]}>
  <div class="wrap">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="display-title">
      {accentIndex >= 0 ? (
        <>
          {beforeAccent}
          {beforeAccent && " "}
          <span>{accent}</span>
          {afterAccent && <> {afterAccent}</>}
        </>
      ) : (
        title
      )}
    </h1>
    <p class:list={["lead", { "lead--centered": centered }]}>{lead}</p>
    <slot />
  </div>
</section>
