---
type Props = {
  eyebrow: string;
  title: string;
  lead: string;
};

const { eyebrow, title, lead } = Astro.props;
const imagePath = Astro.url.pathname === "/" ? "images/site/mns1-terminal-hero.jpg" : "../images/site/mns1-terminal-hero.jpg";
---

<section class="hero page-hero" style={`--page-hero-image: url("${imagePath}")`}>
  <div class="wrap">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="display-title">{title}</h1>
    <p class="lead">{lead}</p>
    <slot />
  </div>
</section>
